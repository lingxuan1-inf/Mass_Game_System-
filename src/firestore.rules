rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Require a signed-in organizer for every read and write.
    // Firebase Authentication is the real enforcement layer — the
    // MM/OCCOM passwords stored in these documents are only a
    // soft, in-app boundary between already-authenticated organizers.
    match /massgame/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

